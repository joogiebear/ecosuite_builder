{
  "name": "ecosuite-builder",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "description": "Windows desktop config builder for the Auxilor / EcoSuite plugin ecosystem.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "vite build",
    "desktop": "npm run build && electron . --dist",
    "verify": "npm run build && node scripts/smoke-build.mjs",
    "dist": "npm run build && electron-builder --win && node scripts/package-release.mjs"
  },
  "build": {
    "appId": "com.ecosuite.builder",
    "productName": "EcoSuite Builder",
    "directories": {
      "output": "release/latest"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "dir",
      "signAndEditExecutable": false
    },
    "electronLanguages": [
      "en-US"
    ]
  },
  "dependencies": {
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "js-yaml": "^4.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.1",
    "electron": "^35.2.0",
    "electron-builder": "^26.8.1",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  }
}
